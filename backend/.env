# App Configuration
APP_NAME="Premium Fashion eCommerce API"
APP_ENV=development
DEBUG=true

# Security
JWT_SECRET=4f9ea9a9c2e01df2220551a37c9f80a4bbbe1a7df70a6c6e73dbd637c35fa290
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_db

# Redis Caching & Rate Limiting
REDIS_URL=redis://localhost:6379/0

# Storage (Cloudflare R2 mock defaults)
R2_BUCKET_NAME=fashion-apparel-assets
R2_ACCESS_KEY_ID=mock_access_key
R2_SECRET_ACCESS_KEY=mock_secret_key
R2_ENDPOINT_URL=https://mock.r2.cloudflarestorage.com

# Mail Provider (SMTP mock / local delivery)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=mock_user
SMTP_PASSWORD=mock_password
SMTP_FROM_EMAIL=noreply@premiumfashion.com
